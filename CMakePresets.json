{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 15,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_Mac_arm",
            "toolset": {
                "value": "host",
                "strategy": "external"
            }
        },
        {
            "name": "build_mac_arm",
            "inherits": "base",
            "displayName": "build_mac_arm",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "build_mac_arm_tls",
            "inherits": "build_mac_arm",
            "displayName": "build_mac_arm_tls",
            "binaryDir": "${sourceDir}/build-tls-mac-arm",
            "cacheVariables": {
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "fast-dev",
            "inherits": "base",
            "displayName": "Fast Dev (Debug, tests only)",
            "binaryDir": "${sourceDir}/build-fastdev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "OFF",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "msan-debug",
            "inherits": "base",
            "displayName": "MemorySanitizer Debug",
            "binaryDir": "${sourceDir}/build-msan",
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "ON",
                "ENABLE_MSAN": "ON"
            }
        },
        {
            "name": "asan-debug",
            "inherits": "base",
            "displayName": "AddressSanitizer Debug",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "ON",
                "ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "ubsan-release",
            "inherits": "base",
            "displayName": "UBSan RelWithDebInfo",
            "binaryDir": "${sourceDir}/build-ubsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_EXAMPLES": "ON",
                "ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "tsan-debug",
            "inherits": "base",
            "displayName": "ThreadSanitizer Debug",
            "binaryDir": "${sourceDir}/build-tsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "OFF",
                "BUILD_TESTS": "ON",
                "ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "tsan-ubsan",
            "inherits": "base",
            "displayName": "TSan + UBSan Debug (Homebrew LLVM)",
            "binaryDir": "${sourceDir}/build-tsan-ubsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "OFF",
                "BUILD_TESTS": "ON",
                "ENABLE_TSAN": "ON",
                "ENABLE_UBSAN": "ON",
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
            }
        },
        {
            "name": "mac-release",
            "inherits": "base",
            "displayName": "macOS Release -O3 with symbols",
            "binaryDir": "${sourceDir}/build-mac-rel",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_EXAMPLES": "ON",
                "CMAKE_CXX_FLAGS_RELEASE": "-O2 -DNDEBUG -fno-exceptions"
            }
        },
        {
            "name": "relwithdebinfo",
            "inherits": "base",
            "displayName": "RelWithDebInfo",
            "binaryDir": "${sourceDir}/build-relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON"
            }
        },
        {
            "name": "tls-relwithdebinfo",
            "inherits": "base",
            "displayName": "TLS RelWithDebInfo",
            "binaryDir": "${sourceDir}/build-tls-relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Windows Debug (MSVC)",
            "description": "Visual Studio 17 2022, Debug, examples and tests on Windows",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "tls-windows-debug",
            "inherits": "windows-debug",
            "displayName": "Windows Debug TLS (MSVC)",
            "description": "Visual Studio 17 2022, Debug, examples and tests on Windows with TLS enabled",
            "binaryDir": "${sourceDir}/build-tls",
            "cacheVariables": {
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "tls-windows-debug-ninja",
            "displayName": "Windows Debug TLS (Ninja)",
            "description": "Ninja, Debug, examples and tests on Windows with TLS enabled",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-tls-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON",
                "OPENSSL_ROOT_DIR": "C:/OpenSSL-Win64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-release",
            "displayName": "MinGW-w64 Release (Wine)",
            "description": "Cross-compile for Windows x86-64 with MinGW-w64 in Release mode",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-mingw-rel",
            "toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON",
                "CMAKE_CROSSCOMPILING_EMULATOR": "/opt/homebrew/bin/wine"
            }
        },
        {
            "name": "tls-mingw-release",
            "inherits": "mingw-release",
            "displayName": "MinGW-w64 Release TLS (Wine)",
            "description": "Cross-compile for Windows x86-64 with MinGW-w64 in Release mode and TLS enabled",
            "binaryDir": "${sourceDir}/build-mingw-rel-tls",
            "cacheVariables": {
                "AISOCKS_ENABLE_TLS": "ON"
            }
        },
        {
            "name": "coverage",
            "inherits": "base",
            "displayName": "Coverage (Clang source-based)",
            "binaryDir": "${sourceDir}/build-coverage",
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_EXAMPLES": "OFF",
                "ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "mingw-debug",
            "displayName": "MinGW-w64 Debug (Wine)",
            "description": "Cross-compile for Windows x86-64 with MinGW-w64; run tests under Wine",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-mingw",
            "toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTS": "ON",
                "AISOCKS_ENABLE_TLS": "ON",
                "CMAKE_CROSSCOMPILING_EMULATOR": "/opt/homebrew/bin/wine"
            }
        },
        {
            "name": "tls-mingw-debug",
            "inherits": "mingw-debug",
            "displayName": "MinGW-w64 Debug TLS (Wine)",
            "description": "Cross-compile for Windows x86-64 with MinGW-w64 and TLS enabled; run tests under Wine",
            "binaryDir": "${sourceDir}/build-mingw-tls",
            "cacheVariables": {
                "AISOCKS_ENABLE_TLS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "base-build",
            "hidden": true,
            "jobs": 8
        },
        {
            "name": "build_mac_arm",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "build_mac_arm"
        },
        {
            "name": "build_mac_arm_tls",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm_tls",
            "displayName": "Build build_mac_arm_tls"
        },
        {
            "name": "fast-dev",
            "inherits": "base-build",
            "configurePreset": "fast-dev",
            "displayName": "Build Fast Dev"
        },
        {
            "name": "msan-debug",
            "inherits": "base-build",
            "configurePreset": "msan-debug",
            "displayName": "Build MemorySanitizer Debug"
        },
        {
            "name": "asan-debug",
            "inherits": "base-build",
            "configurePreset": "asan-debug",
            "displayName": "Build AddressSanitizer Debug"
        },
        {
            "name": "ubsan-release",
            "inherits": "base-build",
            "configurePreset": "ubsan-release",
            "displayName": "Build UBSan RelWithDebInfo"
        },
        {
            "name": "tsan-debug",
            "inherits": "base-build",
            "configurePreset": "tsan-debug",
            "displayName": "Build ThreadSanitizer Debug"
        },
        {
            "name": "tsan-ubsan",
            "inherits": "base-build",
            "configurePreset": "tsan-ubsan",
            "displayName": "Build TSan + UBSan (Homebrew LLVM)"
        },
        {
            "name": "mac-release",
            "inherits": "base-build",
            "configurePreset": "mac-release",
            "displayName": "Build macOS Release -O3"
        },
        {
            "name": "relwithdebinfo",
            "inherits": "base-build",
            "configurePreset": "relwithdebinfo",
            "displayName": "Build RelWithDebInfo"
        },
        {
            "name": "tls-relwithdebinfo",
            "inherits": "base-build",
            "configurePreset": "tls-relwithdebinfo",
            "displayName": "Build TLS RelWithDebInfo"
        },
        {
            "name": "coverage",
            "inherits": "base-build",
            "configurePreset": "coverage",
            "displayName": "Build Coverage"
        },
        {
            "name": "test-socket-basics",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_socket_basics",
            "targets": [
                "test_socket_basics"
            ]
        },
        {
            "name": "test-blocking",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_blocking",
            "targets": [
                "test_blocking"
            ]
        },
        {
            "name": "test-loopback-tcp",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_loopback_tcp",
            "targets": [
                "test_loopback_tcp"
            ]
        },
        {
            "name": "test-construction",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_construction",
            "targets": [
                "test_construction"
            ]
        },
        {
            "name": "test-new-features",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_new_features",
            "targets": [
                "test_new_features"
            ]
        },
        {
            "name": "test-error-messages",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_error_messages",
            "targets": [
                "test_error_messages"
            ]
        },
        {
            "name": "test-poller",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_poller",
            "targets": [
                "test_poller"
            ]
        },

        {
            "name": "test-socket-factory",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_socket_factory",
            "targets": [
                "test_socket_factory"
            ]
        },
        {
            "name": "test-http-poll-server",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build test_http_poll_server",
            "targets": [
                "test_http_poll_server"
            ]
        },
        {
            "name": "advanced-file-server",
            "inherits": "base-build",
            "configurePreset": "build_mac_arm",
            "displayName": "Build advanced_file_server",
            "targets": [
                "advanced_file_server"
            ]
        },
        {
            "name": "mingw-debug",
            "inherits": "base-build",
            "configurePreset": "mingw-debug",
            "displayName": "Build MinGW-w64 Debug"
        },
        {
            "name": "tls-mingw-debug",
            "inherits": "base-build",
            "configurePreset": "tls-mingw-debug",
            "displayName": "Build MinGW-w64 Debug TLS"
        },
        {
            "name": "mingw-release",
            "inherits": "base-build",
            "configurePreset": "mingw-release",
            "displayName": "Build MinGW-w64 Release"
        },
        {
            "name": "tls-mingw-release",
            "inherits": "base-build",
            "configurePreset": "tls-mingw-release",
            "displayName": "Build MinGW-w64 Release TLS"
        },
        {
            "name": "windows-unix-throughput",
            "inherits": "base-build",
            "configurePreset": "windows-debug",
            "displayName": "Build unix_throughput (Windows Debug)",
            "configuration": "Debug",
            "targets": [ "unix_throughput" ]
        },
        {
            "name": "windows-relwithdebinfo",
            "inherits": "base-build",
            "configurePreset": "windows-debug",
            "displayName": "Build All (Windows RelWithDebInfo)",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "tls-windows-debug",
            "inherits": "base-build",
            "configurePreset": "tls-windows-debug",
            "displayName": "Build All (Windows Debug TLS)",
            "configuration": "Debug"
        },
        {
            "name": "tls-windows-debug-ninja-build",
            "inherits": "base-build",
            "configurePreset": "tls-windows-debug-ninja",
            "displayName": "Build All (Windows Debug TLS Ninja)",
            "configuration": "Debug"
        },
        {
            "name": "tls-windows-relwithdebinfo",
            "inherits": "base-build",
            "configurePreset": "tls-windows-debug",
            "displayName": "Build All (Windows RelWithDebInfo TLS)",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "windows-unix-throughput-relwithdebinfo",
            "inherits": "base-build",
            "configurePreset": "windows-debug",
            "displayName": "Build unix_throughput (Windows RelWithDebInfo)",
            "configuration": "RelWithDebInfo",
            "targets": [ "unix_throughput" ]
        }
        ,
        {
            "name": "windows-advanced-file-server-tls",
            "inherits": "base-build",
            "configurePreset": "windows-debug",
            "displayName": "Build advanced_file_server (Windows TLS)",
            "configuration": "Debug",
            "targets": [ "advanced_file_server" ]
        },
        {
            "name": "windows-advanced-file-server-tls-release",
            "inherits": "base-build",
            "configurePreset": "windows-debug",
            "displayName": "Build advanced_file_server (Windows TLS Release w/ Symbols)",
            "configuration": "RelWithDebInfo",
            "targets": [ "advanced_file_server" ]
        }
    ],
    "testPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug",
            "configuration": "Debug",
            "displayName": "Windows Debug Tests"
        },
        {
            "name": "windows-relwithdebinfo",
            "configurePreset": "windows-debug",
            "configuration": "RelWithDebInfo",
            "displayName": "Windows RelWithDebInfo Tests"
        },
        {
            "name": "build_mac_arm",
            "configurePreset": "build_mac_arm",
            "displayName": "build_mac_arm"
        },
        {
            "name": "build_mac_arm_tls",
            "configurePreset": "build_mac_arm_tls",
            "displayName": "build_mac_arm_tls"
        },
        {
            "name": "fast-dev",
            "configurePreset": "fast-dev",
            "displayName": "Fast Dev Tests",
            "execution": {
                "jobs": 8,
                "noTestsAction": "error"
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "displayName": "Coverage Tests"
        },
        {
            "name": "tls-windows-debug",
            "configurePreset": "tls-windows-debug",
            "configuration": "Debug",
            "displayName": "Windows Debug TLS Tests"
        },
        {
            "name": "tls-windows-debug-ninja-test",
            "configurePreset": "tls-windows-debug-ninja",
            "configuration": "Debug",
            "displayName": "Windows Debug TLS Ninja Tests",
            "execution": {
                "jobs": 8,
                "noTestsAction": "error"
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "tls-windows-relwithdebinfo",
            "configurePreset": "tls-windows-debug",
            "configuration": "RelWithDebInfo",
            "displayName": "Windows RelWithDebInfo TLS Tests"
        },
        {
            "name": "mingw-debug",
            "configurePreset": "mingw-debug",
            "displayName": "Run Tests (MinGW-w64 / Wine)",
            "execution": {
                "noTestsAction": "error",
                "jobs": 8
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "tls-mingw-debug",
            "configurePreset": "tls-mingw-debug",
            "displayName": "Run TLS Tests (MinGW-w64 / Wine)",
            "execution": {
                "noTestsAction": "error",
                "jobs": 8
            },
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}