# --------------------------------------------------------------------------
# clangd configuration for AISocks (cross-platform: Windows, macOS, Linux)
# --------------------------------------------------------------------------

# Always use the native build directory for clangd.
# "build" is the binaryDir for the "debug" CMake preset on all platforms.
# The cross-compilation builds (build-mingw, build-msan) must never drive
# clangd -- they produce foreign-compiler commands that cause false errors.
CompileFlags:
  CompilationDatabase: .
  # compile_commands.json is automatically copied to the source root by CMake
  # on every configure (any OS, any build dir), so clangd always finds it here.
  # Fallback include path so clangd resolves <Socket.h> even before
  # compile_commands.json is regenerated after a clean.
  Add:
    - "-Ilib/include"
    - "-Iexamples"
  # Remove Windows-specific Clang flags that confuse clangd
  # Also remove PCH flags to avoid circular dependency when parsing headers
  # that are themselves included in the PCH (e.g., TcpSocket.h in test_pch.h)
  Remove:
    - "-Xclang"
    - "--dependent-lib=*"
    - "-gcodeview"
    - "-include-pch"
    - "-Winvalid-pch"
    - "-include"
    - "**/cmake_pch.hxx*"

# Do not index the C++ standard library headers or pull them into
# completion/navigation results. This keeps "Go to Definition" fast
# and avoids thousands of irrelevant symbols appearing in autocomplete.
Index:
  StandardLibrary: false

Diagnostics:
  UnusedIncludes: None
  Suppress:
    - unused-includes

# Disable inline hints (inlay hints) that clutter the code
InlayHints:
  Enabled: false
  # Or be more selective:
  # ParameterNames: false
  # DeducedTypes: false
  # Designators: false

# ------------------------------------------------------------------
# Per-path overrides: silence diagnostics and skip background
# indexing for system SDK, OS, and socket headers (cross-platform).
# ------------------------------------------------------------------
---
If:
  PathMatch:
    # macOS system headers
    - /Applications/Xcode.app/.*
    - /usr/include/.*
    - /usr/local/include/.*
    - /Library/Developer/.*
    # Ignore generated CMake PCH files and CI configuration
    - .*/cmake_pch\.hxx\.cxx
    - .*\.github/workflows/ci\.yml
    - .*/\.github/workflows/ci\.yml
    # Windows system headers
    - .*\\Windows Kits\\.*
    - .*\\Microsoft Visual Studio\\.*
    - .*\\LLVM\\.*
    - .*\\ClangPowerTools\\.*
    - C:\\Program Files.*
Diagnostics:
  Suppress: "*"
Index:
  Background: Skip
