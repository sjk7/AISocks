{
  "cmake.buildDirectory": "${workspaceFolder}/build_Mac_arm",
  "cmake.generator": "Ninja",
  "cmake.configureOnOpen": true,
  "cmake.buildBeforeRun": true,
  "cmake.defaultBuildType": "Debug",
  "cmake.showAdvanced": true,
  "cmake.useCMakePresets": "always",
  "cmake.defaultConfigurePreset": "tls-windows-relwithdebinfo-ninja",
  "cmake.statusbar.advanced": {
    "target": "visible",
    "buildType": "visible",
    "kit": "visible",
    "launchTarget": "visible",
    "debug": "visible",
    "run": "visible"
  },
  "cmake.configureArgs": [
    "-DBUILD_EXAMPLES=ON",
    "-DBUILD_TESTS=ON"
  ],
  "cmake.autoRestartBuild": true,
  "cmake.enableTraceLogging": true,
  "githubPullRequests.notifications": "pullRequests",
  "githubPullRequests.experimental.notificationsMarkPullRequests": "markAsRead",
  "github-actions.workflows.pinned.workflows": [".github/workflows/ci.yml"],
  "github-actions.workflows.pinned.refresh.enabled": true,
  "github-actions.workflows.pinned.refresh.interval": 30,
  "files.associations": {
    ".github/workflows/*.yml": "yaml",
    ".github/workflows/*.yaml": "yaml"
  },
  "chat.tools.terminal.autoApprove": {
    "/^gh(\\s|$).*$": true,
    "/^git (status|diff|show\\b.*|log\\b.*|branch\\b.*|checkout\\b.*|switch\\b.*|restore\\b.*|add\\b.*|commit\\b.*|push\\b.*|pull\\b.*|fetch\\b.*|rebase\\b.*|merge\\b.*|tag\\b.*)$/": true,
    "/^cmake(\\s|$).*$": true,
    "/^(ctest|ninja|make)(\\s|$).*$": true,
    "/^(lldb|gdb|lldb-server)(\\s|$).*$": true,
    "/^(./)?build(_[A-Za-z0-9-]+)?\\/(.+)$/": true,
    "/^(python3?|pytest|node|npm|pnpm|yarn)(\\s|$).*$": true,
    "/(^|\\s)(rm -rf \\/|mkfs|dd if=|shutdown|reboot)(\\s|$)/": false
  }
}
