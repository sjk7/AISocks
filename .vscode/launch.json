{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug test_http_poll_server",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build_Mac_arm/tests/test_http_poll_server",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "sourceMap": {
        "${workspaceFolder}": "${workspaceFolder}"
      },
      "preLaunchTask": "Build test_http_poll_server"
    },
    {
      "name": "Debug advanced_file_server",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build_Mac_arm/advanced_file_server",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "sourceMap": {
        "${workspaceFolder}": "${workspaceFolder}"
      },
      "preLaunchTask": "Build advanced_file_server"
    },
    {
      "name": "Debug unix_throughput (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/Debug/unix_throughput.exe",
      "args": ["5"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "Build unix_throughput (Windows Debug)"
    },
    {
      "name": "Debug unix_throughput (Windows RelWithDebInfo)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/RelWithDebInfo/unix_throughput.exe",
      "args": ["5"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "Build unix_throughput (Windows RelWithDebInfo)"
    },
    {
      "name": "Launch advanced_file_server (RelWithDebInfo)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-relwithdebinfo/advanced_file_server.exe",
      "args": [],
      "cwd": "${workspaceFolder}/build-relwithdebinfo",
      "console": "integratedTerminal",
      "preLaunchTask": "Build advanced_file_server (RelWithDebInfo)"
    }
    ,
    {
      "name": "Docker arm64 MSan: test_http_poll_server",
      "type": "lldb",
      "request": "custom",
      "targetCreateCommands": [
        "target create \"${workspaceFolder}/build-msan/tests/test_http_poll_server\"",
        "settings set target.source-map \"/workspace\" \"${workspaceFolder}\"",
        "breakpoint set --name main"
      ],
      "processCreateCommands": [
        "gdb-remote localhost:1234"
      ],
      "preLaunchTask": "Docker: Start lldb-server for test_http_poll_server",
      "postDebugTask": "Docker: Kill debug container"
    },
    {
      "name": "Docker arm64 MSan: advanced_file_server",
      "type": "lldb",
      "request": "custom",
      "targetCreateCommands": [
        "target create \"${workspaceFolder}/build-msan/advanced_file_server\"",
        "settings set target.source-map \"/workspace\" \"${workspaceFolder}\"",
        "breakpoint set --name main"
      ],
      "processCreateCommands": [
        "gdb-remote localhost:1234"
      ],
      "preLaunchTask": "Docker: Start lldb-server for advanced_file_server",
      "postDebugTask": "Docker: Kill debug container"
    }
  ]
}
